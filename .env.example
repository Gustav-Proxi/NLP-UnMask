# LLM — use OpenAI directly or OpenRouter (https://openrouter.ai)
OPENAI_API_KEY=sk-...
# If using OpenRouter, set base URL:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-4o

# Embedding — Gemini or OpenAI fallback
GOOGLE_API_KEY=AIza...
EMBEDDING_PROVIDER=openai   # "gemini" | "openai"

# Qdrant (default: local)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=unmask_anatomy
